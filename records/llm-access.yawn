id: records/llm-access
title: "llm access"
kind: record-log
status: v0-seed
updated: 2026-07-01

purpose: >
  Record what an LLM or agent detected, read, used, inferred from, or changed
  while helping with the Yawn Space.

record_when:
  - a file or folder shapes the answer
  - a command output changes the next move
  - an external source is used
  - a tool reads or writes material state
  - an inference depends on a specific record

entry_shape:
  timestamp: ""
  model_or_agent: ""
  detected_surface: ""
  used_surface: ""
  evidence_seen: ""
  inference_made: ""
  next_move_effect: ""
  boundary: ""

current_entries:
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "local git repo and GitHub repo yawn-ai/.yawn"
    used_surface: "git, gh cli, local .yawn filesystem"
    evidence_seen: "remote existed with public visibility, main branch, and MIT license before seed publication"
    inference_made: "local filesystem should be connected to origin and published to main"
    next_move_effect: "added GitHub address, MIT/The Yawn Company ownership language, usage instructions, and pushed seed filesystem"
    boundary: "recorded AI/tool access as material time; AI output is not authority"
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "live GitHub first view and GitHub Pages feedback form"
    used_surface: "in-app browser, git, gh cli, local .yawn filesystem"
    evidence_seen: "GitHub renders readme.md first; Pages renders feedback/index.html at the public feedback URL"
    inference_made: "readme.md needed the first-hit awakening explanation, while readme.yawn stays canonical"
    next_move_effect: "expanded readme.md, added feedback intake/database contracts, enabled Pages, verified feedback form"
    boundary: "browser review read public pages only; no feedback email was sent"
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "GitHub open-source contribution flow and Codex app automation"
    used_surface: "git, gh cli, GitHub issue-template files, Codex automation_update"
    evidence_seen: "user requested AI-agent contributor workflow, easy feedback, and automation; GitHub issue chooser requires sign-in"
    inference_made: "repo needs both public GitHub issue forms and a local automation that triages signals without taking hidden authority"
    next_move_effect: "added contributing.md, issue forms, PR template, contributor-agent docs, automation files, labels, and hourly triage automation"
    boundary: "automation is inspection/classification only; no autonomous commits, pushes, merges, comments, email sends, or database writes"
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "user request for yawn.bot daily service automation"
    used_surface: "local .yawn filesystem, Codex automation_update, GitHub repo context"
    evidence_seen: "user asked to create the bot/service that can contribute, name it yawn.bot, and connect it via Codex as a daily automation"
    inference_made: "yawn.bot should be represented as a service identity plus a conservative daily Codex automation contract"
    next_move_effect: "created agents/yawn.bot.yawn, automation/yawn.bot.daily.yawn, records/yawn.bot-log.yawn, and daily Codex automation yawn-bot-daily-repo-contributor"
    boundary: "service can inspect, classify, and recommend by default; external writes and GitHub account/app setup remain approval-bound"
  - timestamp: "2026-07-01"
    model_or_agent: "codex as yawn.bot verification"
    detected_surface: "active yawn.bot automation, GitHub repo state, feedback page, parser and database contracts"
    used_surface: "Codex automation view, gh cli, Invoke-WebRequest, local .yawn files"
    evidence_seen: "automation active; open issues 0; open PRs 0; feedback page HTTP 200; feedback parser/database contracts exist"
    inference_made: "before yawn.bot can commit from feedback, the repo needs an explicit feedback-to-thesis-to-risk-to-commit gate"
    next_move_effect: "added automation/yawn.bot.feedback-loop.yawn and records/yawn.bot-verification-2026-07-01.yawn"
    boundary: "manual verification is not a scheduled run-now event; no external product feedback pattern exists yet"
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "user-approved architecture observer implementation plan"
    used_surface: "local .yawn filesystem, gh cli, Codex automation_update, private staging repo"
    evidence_seen: "user requested implementation of policy, private staging, automations, ledgers, README audit, license audit, and rising repo learning"
    inference_made: "yawn.bot should be encoded as architecture observer with separate read-only observer and private draft PR proposer modes"
    next_move_effect: "created policy, automation contracts, ledgers, private staging repo setup, and Codex automations"
    boundary: "public .yawn remains sanitized; private PR lane does not grant merge or main-branch authority"

proof:
  source:
    - records/access-log.yawn
    - agents/orientation.yawn
  status: seed-backed
