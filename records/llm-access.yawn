id: records/llm-access
title: "llm access"
kind: record-log
status: v0-seed
updated: 2026-07-01

purpose: >
  Record what an LLM or agent detected, read, used, inferred from, or changed
  while helping with the Yawn Space.

record_when:
  - a file or folder shapes the answer
  - a command output changes the next move
  - an external source is used
  - a tool reads or writes material state
  - an inference depends on a specific record

entry_shape:
  timestamp: ""
  model_or_agent: ""
  detected_surface: ""
  used_surface: ""
  evidence_seen: ""
  inference_made: ""
  next_move_effect: ""
  boundary: ""

current_entries:
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "local git repo and GitHub repo yawn-ai/.yawn"
    used_surface: "git, gh cli, local .yawn filesystem"
    evidence_seen: "remote existed with public visibility, main branch, and MIT license before seed publication"
    inference_made: "local filesystem should be connected to origin and published to main"
    next_move_effect: "added GitHub address, MIT/The Yawn Company ownership language, usage instructions, and pushed seed filesystem"
    boundary: "recorded AI/tool access as material time; AI output is not authority"
  - timestamp: "2026-07-01"
    model_or_agent: "codex"
    detected_surface: "live GitHub first view and GitHub Pages feedback form"
    used_surface: "in-app browser, git, gh cli, local .yawn filesystem"
    evidence_seen: "GitHub renders readme.md first; Pages renders feedback/index.html at the public feedback URL"
    inference_made: "readme.md needed the first-hit awakening explanation, while readme.yawn stays canonical"
    next_move_effect: "expanded readme.md, added feedback intake/database contracts, enabled Pages, verified feedback form"
    boundary: "browser review read public pages only; no feedback email was sent"

proof:
  source:
    - records/access-log.yawn
    - agents/orientation.yawn
  status: seed-backed
