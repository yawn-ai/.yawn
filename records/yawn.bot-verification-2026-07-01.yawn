  - records/yawn.bot-log.yawn

meaningful_suggestion:
  summary: >
    Add an explicit feedback-to-thesis-to-risk-to-commit gate before allowing
    yawn.bot to make repo changes from feedback.
  thesis: >
    yawn.bot should not commit from vibes or isolated signals. It should commit
    only after feedback forms a clear thesis, the affected node is known, risks
    and dissent are named, proof is defined, and authority is present.
  suggested_change: "Add automation/yawn.bot.feedback-loop.yawn and update the daily automation prompt to use it."
  proof_needed: "A future run should classify real feedback into signal strength, thesis, risk, proof, and commit readiness."

risk_review:
  - risk: "bot commits too early from thin feedback"
    mitigation: "require thesis_ready or commit_ready signal strength"
  - risk: "bot overfits to one loud user"
    mitigation: "require repeated signals or a high-severity proof-backed issue"
  - risk: "automation appears to have hidden authority"
    mitigation: "keep authorization state explicit in every daily report"
  - risk: "direct main commits hide review"
    mitigation: "default to branch or draft PR unless current human authorization is explicit"

decision:
  signal_strength: "none for product feedback; commit_ready for the bot's own operating rule"
  authorization_state: "human requested this verification and bot-commit pathway in the current run"
  action_taken: "prepare and commit the feedback-loop gate as a yawn.bot verification improvement"

proof:
  source:
    - automation/yawn.bot.daily.yawn
    - agents/yawn.bot.yawn
    - feedback/codex-t4o-parser.yawn
    - database/feedback-intake.yawn
  status: verified
