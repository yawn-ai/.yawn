id: records/access-log
title: "access log"
kind: record-log
status: v0-seed
updated: 2026-07-01

purpose: >
  Track meaningful accesses used by a human, agent, LLM, tool, or integration.

entry_shape:
  id: ""
  timestamp: ""
  actor: "human | agent | llm | tool | integration"
  access_type: "file | command | app | github | web | database | backup | other"
  surface: ""
  action: "read | write | search | inspect | create | update | delete | restore"
  reason: ""
  output_or_evidence: ""
  risk_or_boundary: ""
  linked_yawn: ""

current_entries:
  - id: "2026-07-01-github-publication"
    timestamp: "2026-07-01"
    actor: "agent"
    access_type: "github"
    surface: "https://github.com/yawn-ai/.yawn"
    action: "inspect | update"
    reason: "verify repo address, license state, remote branch, and publish the seed filesystem"
    output_or_evidence: "repo is public at https://github.com/yawn-ai/.yawn; seed commit 4f7773c pushed to main"
    risk_or_boundary: "LICENSE kept uppercase as GitHub compatibility exception; human authority remains visible"
    linked_yawn: "references/ownership-and-license.yawn"
  - id: "2026-07-01-feedback-pages-validation"
    timestamp: "2026-07-01"
    actor: "agent"
    access_type: "github"
    surface: "https://github.com/yawn-ai/.yawn and https://yawn-ai.github.io/.yawn/feedback/"
    action: "inspect | update"
    reason: "review repo as a new user and verify the feedback form path"
    output_or_evidence: "GitHub README now starts with the fundamental problem and Pages feedback form renders with five fields"
    risk_or_boundary: "did not submit feedback email; only verified rendering"
    linked_yawn: "feedback/form.yawn"
  - id: "2026-07-01-agent-contributor-workflow"
    timestamp: "2026-07-01"
    actor: "agent"
    access_type: "github"
    surface: "https://github.com/yawn-ai/.yawn"
    action: "inspect | update"
    reason: "create open-source AI-agent contributor path and feedback triage automation"
    output_or_evidence: "issue templates and labels are present; automation yawn-repo-feedback-triage exists"
    risk_or_boundary: "GitHub issue creation requires sign-in; dedicated bot/GitHub App recommended later instead of hidden personal-account automation"
    linked_yawn: "automation/github-feedback-triage.yawn"
  - id: "2026-07-01-yawn-bot-daily-automation"
    timestamp: "2026-07-01"
    actor: "agent"
    access_type: "app | github | file"
    surface: "Codex automation, local .yawn filesystem, https://github.com/yawn-ai/.yawn"
    action: "inspect | create | update"
    reason: "create yawn.bot as the daily repo-contributor service role"
    output_or_evidence: "automation yawn-bot-daily-repo-contributor exists and is linked from agents/yawn.bot.yawn"
    risk_or_boundary: "Codex daily loop can inspect and recommend; GitHub writes require exact human authorization"
    linked_yawn: "agents/yawn.bot.yawn"

proof:
