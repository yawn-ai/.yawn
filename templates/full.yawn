created: ""
updated: ""

source:
  template: templates/full.yawn
  origin: "" # self-report | conversation | transcript | repo | agent | artifact | observation
  raw_material: ""
  source_refs: []
  quotes: []
  privacy: private # private | shared | public
  consent:
    recorded_with_consent: unknown
    shareable_with: []
    do_not_share_with: []

movement:
  stage: observe # observe | orient | steer | move | replay
  mode: hold # observe | ask | hold | test | move
  loop:
    - notice
    - orient
    - infer
    - name_gap
    - protect_boundary
    - choose_bounded_move
    - prove_change
    - update_memory

observer:
