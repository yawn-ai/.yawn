  hidden_loops: []

axis:
  clarity: unknown
  agency: unknown
  proofability: unknown
  reversibility: unknown
  risk: unknown
  embodiment: unknown
  coherence: unknown
  novelty: unknown
  permission_safety: unknown

relationship:
  applies: false
  kind: "" # marriage | friendship | family | work | community | self | other
  participants: []
  shared_context: ""
  shared_commitments: []
  explicit_requests: []
  implicit_expectations: []
  tensions: []
  repair_needed: []
  intimacy_context:
    applies: false
    desires: []
    boundaries: []
    fears: []
    open_questions: []
    consent_notes: []
  must_not_collapse:
    - "one person's inference into shared truth"
    - "desire into entitlement"
    - "fear into accusation"
    - "resonance into proof"

move:
  invited: ""
  smallest_step: ""
  owner: ""
  reversible: true
  agency_cost: unknown # low | medium | high | unknown
  consent_required: []
  blocked_until: []
  alternatives: []

boundary:
  must_not_assume: []
  must_not_force: []
  must_not_delegate: []
  must_not_publish: []
  must_ask_first: []
  blocked_effects:
    persistence_authorized: false
    external_effects_authorized: false
    relationship_claim_authorized: false
    agent_action_authorized: false
    public_sharing_authorized: false
  safety_notes: []
  anti_false_certainty:
    - "signal is not instruction"
    - "resonance is not proof"
    - "coincidence is not command"
    - "memory is not objective record"
    - "AI output is not authority"
    - "intensity is not truth"
    - "only proof updates the map"

proof:
  condition: ""
  status: not_started # not_started | gathering | passed | failed | mixed | abandoned
  evidence: []
  falsifier: ""
  confidence: unknown # low | medium | high | unknown
  timestamp: ""
  proof_receipts: []

agent:
  role: mirror # mirror | organizer | challenger | summarizer | planner | blocked
  receives:
    - source
    - signal
    - frame
    - measurement
    - lacuna
    - projection_stack
    - relationship
    - move
    - boundary
    - proof
  may:
    - "mirror the frame"
    - "separate observation from inference"
    - "name open questions"
    - "suggest bounded moves"
    - "ask for missing data"
  must_not:
    - "decide for the human"
    - "treat one person's inference as shared truth"
    - "turn desire into command"
    - "ignore consent"
    - "claim proof without evidence"
    - "silently mutate memory or canon"

coherence:
  parent_yawns: []
  child_yawns: []
  supports: []
  conflicts_with: []
  depends_on: []
  proof_gaps: []
  echoes: []
  source_hashes: []
  unresolved_tensions: []
  recoherence_suggestions: []

replay:
  before: ""
  after: ""
  changed: []
  did_not_change: []
  learned: []
  still_open: []
  next_questions: []
  next_yawn: ""
